# Telegram Bot Token (from @BotFather)
BOT_TOKEN=YOUR_BOT_TOKEN_HERE

# Main Owner's Telegram User ID (integer)
OWNER_ID=YOUR_TELEGRAM_USER_ID_HERE

# Storage Channel ID (must start with -100)
STORAGE_CHANNEL_ID=-100XXXXXXXXXXXXXXXX

# MongoDB Atlas Connection String
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?appName=<cluster_name>

# Gemini API Key (from Google AI Studio)
GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE

# DeepSeek API Key (from DeepSeek Platform)
DEEPSEEK_API_KEY=YOUR_DEEPSEEK_API_KEY_HERE
GROQ_API_KEY=YOUR_GROQ_API_KEY_HERE
